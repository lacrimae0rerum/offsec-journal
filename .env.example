# Copy to .env and adjust. `make install` also generates a minimal .env.
# The app delegates authentication to Authelia; it owns no auth secrets.

# --- Paths ---
DATA_DIR=./data
NOTES_DIR=./notes
DB_PATH=./data/cache.db
LOG_DIR=./logs

# --- Server ---
API_HOST=127.0.0.1
API_PORT=8000

# --- Auth / trust ---
# CSV of IPs allowed to present the Remote-User header (only the reverse proxy).
TRUSTED_PROXY_IPS=127.0.0.1
# Optional: URL the frontend sends users to on logout. Empty = logout hidden.
AUTHELIA_LOGOUT_URL=

# --- Single-tenant mode (optional) ---
# Auto-provision unknown Authelia users into the default team.
SINGLE_TENANT_MODE=false
SINGLE_TENANT_DEFAULT_TEAM=offsec
SINGLE_TENANT_DEFAULT_ROLE=member

# --- Dev only (NEVER in production) ---
# DEV_USER bypasses Authelia entirely: every request authenticates as this user.
# DEV_USER=fer
# Allow DEV_USER on a non-loopback bind (e.g. inside a container). Only on a
# trusted network and with the published port restricted to loopback.
# DEV_ALLOW_LAN=false
